    <string name="help_wind_moisture_title">Moisture cues:</string>
    <string name="help_wind_ccl_line">Orange CCL line - estimated thermal cloud-base level.</string>

    <!-- Help dialog - Cloud -->
    <string name="help_cloud_title">Cloud forecast help</string>
    <string name="help_cloud_summary">Cloud coverage and solar energy at the ground.</string>
    <string name="help_cloud_legend_sun">Sun h - direct sun time above the WMO threshold; clouds may still cover the sky.</string>
    <string name="help_cloud_legend_radiation">W/m² - solar energy reaching the ground; main heating signal for thermals.</string>
    <string name="help_cloud_legend_layers" formatted="false">High / Mid / Low - sky coverage by cloud layer, not cloud thickness.</string>
    <string name="help_cloud_legend_rain" formatted="false">Rain - probability and amount.</string>
    <string name="help_cloud_tip_1">Use cloud mode together with thermic mode to estimate whether lift reaches cloud base or stays blue.</string>
    <string name="help_cloud_tip_2">Compare altitude bands to spot when cloud development starts climbing higher.</string>

